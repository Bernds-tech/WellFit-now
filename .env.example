# WellFit local environment example
# Copy this file to .env.local and fill in your Firebase web app values.
# Never commit .env.local with real project values.
# Do not replace placeholders in this committed template with real secrets.
# CI can build public prerendered pages without these real values, but
# actual Firebase Auth/Firestore usage requires them in .env.local or deployment env.

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Optional staged Firebase App Check rollout for the browser client.
# Register a reCAPTCHA Enterprise site key for the deployed web app and set it
# only in local/deployment environment configuration. Leave empty in CI/emulators.
NEXT_PUBLIC_FIREBASE_APPCHECK_RECAPTCHA_ENTERPRISE_KEY=

# Server-side Beta-1 callable enforcement. Keep false until the App Check client
# is deployed, valid-request metrics have been observed, and the rollout is approved.
# This variable belongs in the Functions/deployment environment, not client code.
BETA1_ENFORCE_APP_CHECK=false

# Optional server-side Buddy KI provider settings.
# Keep real API keys server-side only. Do not expose them with NEXT_PUBLIC_.
# OPENAI_API_KEY and future provider keys must remain server/deployment env values.
BUDDY_KI_MODEL_PROVIDER_ENABLED=false
BUDDY_KI_PROVIDER=rules
OPENAI_API_KEY=
