    "project-register/continuity-dependency-map.json"
  ],
  "allowedStatuses": [
    "open",
    "in_progress",
    "done",
    "blocked",
    "review_required",
    "device_test_required",
    "human_review_required",
    "stale",
    "duplicate",
    "superseded"
  ],
  "severityLevels": [
    "low",
    "medium",
    "high",
    "critical"
  ],
  "findingTypes": [
    "website_completion_gap",
    "route_link_issue",
    "mobile_pwa_issue",
    "visual_layout_issue",
    "content_gap",
    "conversion_gap",
    "seo_gap",
    "trust_compliance_review",
    "beta_waitlist_gap",
    "investor_readiness_gap",
    "analytics_experiment_planning",
    "self_improvement_hypothesis",
    "protected_topic_review",
    "duplicate_architecture_risk"
  ],
  "routeGroups": {
    "global": "Cross-route or framework-level finding; route must be set to global.",
    "public_pages": "Public website and acquisition/help/waitlist surfaces already mapped in website-readiness.json.",
    "legal_pages": "Legal/compliance pages; wording changes remain human-review-required and outside this backlog activation.",
    "desktop_beta_pages": "Desktop beta routes where findings may document UX/readiness gaps but not client authority changes.",
    "mobile_pwa_pages": "Mobile/PWA routes requiring route-specific device, viewport, permission, PWA, and privacy evidence.",
    "protected_or_review_required_pages": "Competition, rewards, economy, marketplace, analytics, AR/camera, health, child, payment, token/NFT, investor, or public-claim routes that require review before changes."
  },
  "backlogEntrySchema": {
    "required": [
      "id",
      "title",
      "status",
      "severity",
      "findingType",
      "route",
      "routeGroup",
      "sourceAgent",
      "sourceFiles",
      "relatedRegisters",
      "finding",
      "evidence",
      "recommendedAction",
      "nextSafeTask",
      "allowedFiles",
      "forbiddenFiles",
      "requiredChecks",
      "humanReviewRequired",
      "protectedTopics",
      "createdDate",
      "updatedDate"
    ],
    "fieldNotes": {
      "id": "Stable unique identifier such as WAB-001.",
      "status": "One of allowedStatuses.",
      "severity": "One of severityLevels.",
      "findingType": "One of findingTypes.",
      "route": "Registered route from website-readiness.json or the literal global.",
      "routeGroup": "One of routeGroups keys.",
      "sourceAgent": "Name from project-register/website-agents.json.",
      "sourceFiles": "Files/reports that produced the finding; do not cite runtime files unless a read-only audit inspected them.",
      "humanReviewRequired": "Must be true for review_required status, high/critical severity, or protected topics."
    }
  },
  "reviewRequiredRules": [
    "Any legal, privacy, health, child, token, NFT, wallet, payment, betting, reward, investor, analytics, public-claim, consent, camera, biometric, location, mission-completion-authority, anti-cheat, or protected data finding must use review_required or human_review_required unless explicitly safe.",
    "High and critical findings must keep humanReviewRequired=true even when the next action is documentation-only.",
    "Trust/compliance findings block conversion_ready, investor_ready, and beta_ready advancement until reviewed.",
    "Review-required entries are preserved as findings; this register never authorizes automatic runtime fixes."
  ],
  "blockedRules": [
    "Use blocked when the next step requires owner/legal/privacy/security/product decisions, unavailable device evidence, missing environment access, or a runtime change outside the current allowed files.",
    "Blocked entries must keep the blocker in finding/evidence and propose only the next safe docs/register/report task.",
    "Blocked does not mean failed; it means automation must stop instead of guessing."
  ],
  "followUpRules": [
    "Every entry must include a concrete nextSafeTask that can be delegated without losing context.",
    "When an entry becomes implementation-ready, create or update an existing agent-task-queue item instead of creating a duplicate architecture.",
    "When findings are resolved, mark entries done, duplicate, superseded, or stale with evidence instead of deleting historical context."
  ],
  "forbiddenAutoActions": [
    "never modify runtime website/app/mobile/legal code",
    "never modify app/** components/** lib/** functions/** firestore.rules public/** package files firebase.json .github/** or native/unity/WellFitBuddyAR/** from this backlog task",
    "never approve PRs",
    "never merge PRs",
    "never enable auto-merge",
    "never enable auto-repair",
    "never deploy",
    "never create duplicate architecture, route registries, design systems, analytics pipelines, or legal-review systems",
    "never auto-fix legal/privacy/health/child/token/payment/reward/investor/analytics/public-claim wording"
  ],
  "reportOutputSchema": {
    "path": "scripts/wellfit-dev-agent/output/website-agent-backlog-report.md",
    "mode": "REPORT_ONLY",
    "readyLine": "WEBSITE_AGENT_BACKLOG_READY=true|false",
    "sections": [
      "mode and forbidden actions",
      "top-level field validation",
      "allowed status/severity/finding type validation",
      "entry schema validation",
      "source agent validation",
      "route/readiness validation",
      "human-review/protected-topic validation",
      "WORK_MAP and TODO_INDEX references",
      "initial backlog summary"
    ]
  },
