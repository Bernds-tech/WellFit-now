  "beta1CanonicalTruth": {
    "economy": {
      "wfp": {
        "definition": "WellFit points (internal in-app game currency).",
        "maxSystemSupply": 25000000000,
        "blockchain": false
      },
      "xp": {
        "definition": "Avatar progression/level metric.",
        "spendable": false
      },
      "wft": {
        "definition": "Potential future SUI token after proven stable operation with 10,000+ users.",
        "beta1Active": false,
        "noConversionPromiseToUsers": true
      }
    },
    "beta1Boundaries": {
      "blockchainActive": false,
      "realTokenActive": false,
      "presaleActive": false,
      "payoutsActive": false,
      "walletTradingActive": false
    },
    "mechanics": {
      "wfpCentralWalletControls": [
        "reward_distributions",
        "pricing",
        "fees",
        "return_flows"
      ],
      "wfpXpStrictlySeparated": true,
      "dynamicValues": [
        "mission_rewards",
        "item_prices",
        "fees"
      ],
      "avatarStateInfluences": [
