      "leon": "Warning, rescue-light, lost-avatar recovery, and heavy rescue mission support."
    }
  },
  "overrides": {
    "overridesOlderSources": true,
    "appliesTo": "beta1",
    "notes": "Conflicting older references about live token launch, presale, investor promises, payout, or blockchain activation are superseded for Beta-1 planning and automation behavior."
  },
  "readByAgents": [
    "scripts/wellfit-dev-agent/wellfit-agent.config.json",
