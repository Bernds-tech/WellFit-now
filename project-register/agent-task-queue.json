{
  "version": "1.0.0",
  "updated": "2026-05-14",
  "status": "active",
  "purpose": "Machine-readable task-selection queue for future WellFit Codex/AI agents. It converts existing governance, work-map, route/API/feature registers, and safety constraints into safe next-task candidates, required first reads, stop rules, checks, and expected PR outputs without creating a parallel product architecture.",
  "sourceOfTruth": {
    "humanRules": "AGENTS.md",
    "currentState": "todolist/CURRENT_PROJECT_STATE.md",
    "workMap": "todolist/WORK_MAP.md",
    "todoIndex": "todolist/TODO_INDEX.md",
    "agentWorkflowRegister": "project-register/agent-workflows.json",
    "internalSourceRegister": "project-register/internal-sources.json",
    "routeRegister": "project-register/routes.json",
    "apiRegister": "project-register/apis.json",
    "featureRegister": "project-register/features.json",
    "feedbackRegister": "project-register/user-feedback.json",
    "riskClassifier": "project-register/risk-classifier.json",
    "definitionOfDone": "project-register/definition-of-done.json",
    "architectureDoc": "docs/architecture/WELLFIT_AGENT_EXECUTION_CONTROLS.md",
    "agentFollowUps": "project-register/agent-follow-ups.json"
  },
  "globalRequiredFirstReadFiles": [
    "AGENTS.md",
    "todolist/CURRENT_PROJECT_STATE.md",
    "todolist/WORK_MAP.md",
    "todolist/TODO_INDEX.md",
    "project-register/agent-workflows.json",
    "project-register/risk-classifier.json",
    "project-register/definition-of-done.json",
    "project-register/product-readiness.json",
    "project-register/agent-follow-ups.json",
    "project-register/agent-work-log.json"
  ],
  "globalForbiddenFiles": [
    "native/unity/WellFitBuddyAR/**",
    "native/unity/WellFitBuddyAR/Assets/Scripts/**",
    "PR #13"
  ],
  "globalForbiddenChanges": [
    "do_not_merge_close_or_depend_on_pr_13",
    "do_not_delete_or_overwrite_unity_files",
    "do_not_create_parallel_architecture",
    "do_not_create_duplicate_routes_apis_feature_modules_or_data_models",
    "do_not_modify_product_logic_unless_task_explicitly_allows_it",
    "do_not_modify_compliance_critical_logic_without_explicit_human_approval",
    "do_not_activate_token_nft_wallet_payment_betting_trading_presale_or_reward_authority"
  ],
  "defaultRequiredChecks": [
    "npm run lint",
    "npx tsc --noEmit",
    "npm run build",
    "npm --prefix functions run check",
    "npm run agent:quality-gate",
    "node scripts/wellfit-dev-agent/src/product-readiness-check.mjs",
    "node scripts/wellfit-dev-agent/src/follow-up-detector.mjs",
    "node scripts/wellfit-dev-agent/src/pr-outcome-recorder.mjs --dry-run"
  ],
  "jsonValidationChecks": [
    "jq empty project-register/agent-task-queue.json",
    "jq empty project-register/definition-of-done.json",
    "jq empty project-register/risk-classifier.json",
    "jq empty project-register/agent-follow-ups.json"
  ],
  "expectedPrOutput": {
    "requiredSections": [
      "summary_of_changed_files",
      "checks_run_with_results",
      "known_risks_or_skipped_checks",
      "dependencies_installed_or_unchanged",
      "next_recommended_task"
    ],
    "mustMention": [
      "branch_name",
      "risk_level",
      "definition_of_done_key_used",
      "whether_product_logic_was_unchanged",
      "whether_protected_areas_were_untouched"
    ]
  },
