{
  "schemaId": "wellfit.agent-dossier.minimum-fields.v1",
  "purpose": "Shared minimum field contract for Safety, Agent, Mission, and Research dossiers shown in the Admin Center.",
  "minimumFields": [
    "title",
    "shortSummary",
    "plainLanguageSummary",
    "problem",
    "proposedChange",
    "whyNow",
    "wellfitBenefit",
    "userBenefit",
    "financialBenefit",
    "internalEconomyImpact",
    "risks",
    "riskLevel",
    "affectedAreas",
    "affectedFiles",
    "requiredChecks",
    "sources",
    "recommendation",
    "ownerDecisionRequired",
    "nextPipelineStep",
    "noRuntimeChanges",
    "noTokenPaymentBlockchain",
    "noRunnerStarted",
    "noBranchOrPrOrMerge",
    "noDeploy"
  ],
  "guardrails": {
    "noRuntimeChangesDefault": true,
    "noTokenPaymentBlockchainDefault": true,
    "noRunnerStartedDefault": true,
    "noBranchOrPrOrMergeDefault": true,
    "noDeployDefault": true,
    "metadataOnlyUntilOwnerApproval": true,
    "persistentOwnerDecisionUntilReapprovalGuard": true,
    "serialBuilderExecutionGroup": "main_repo",
    "maxConcurrentInSerialGroup": 1
  },
  "approvedBuilderBacklogFields": [
    "ownerDecisionId",
    "ownerDecisionStatus",
    "ownerDecisionPersistent",
    "approvedForSerialExecution",
    "reapprovalRequired",
    "reapprovalReason",
    "lastRevalidatedAt",
    "revalidationStatus",
    "staleAfterMainSha",
    "sourceMainShaAtApproval",
    "currentMainShaAtLastValidation",
    "executionOrder",
    "serialGroup",
    "maxConcurrentInSerialGroup",
    "workPackageId",
    "sourceDossierId",
    "sourceDossierType",
    "ownerApproved",
    "baseBranch",
    "baseSha",
    "branchName",
    "prTitle",
    "prBody",
    "allowedFiles",
    "allowedGlobs",
    "blockedFiles",
    "requiredChecks",
    "repairAttemptCount",
    "maxRepairAttempts",
    "noParallelExecution",
    "noAutoMerge",
    "noAutoDeploy",
    "noCanonicalTruthAutonomousChange",
    "noFirestoreRulesChangeUnlessExplicitlyAllowed",
    "noRuntimeRewardLedgerAntiCheatChangeUnlessExplicitlyAllowed",
    "builderPrPlan",
    "githubWriteReady",
    "guardStatus"
  ],
  "verificationPlanFields": [
    "verificationRequired",
    "verificationStatus",
    "verificationChecklist",
    "postMergeChecks",
    "adminSnapshotRequired",
    "uiSmokeSnapshotRequired",
    "lastVerificationAt",
    "verificationFailureReason",
    "createsRepairDossierOnFailure"
  ],
  "conversationIdeaDossier": {
    "collection": "agentConversationIdeaDossiers",
    "callable": "createConversationIdeaDossier",
    "sourceValues": [
      "chat",
      "admin_note",
      "uploaded_transcript",
      "manual"
    ],
    "ownerDecisionRequiredDefault": true,
    "metadataOnly": true,
    "sanitizing": [
      "redact_private_emails",
      "redact_tokens_secrets_sessions",
      "truncate_large_text",
      "no_personal_payloads"
    ],
    "outputFields": [
      "dossierId",
      "title",
      "shortSummary",
      "plainLanguageSummary",
      "problem",
      "proposedChange",
      "whyNow",
      "wellfitBenefit",
      "userBenefit",
      "financialBenefit",
      "internalEconomyImpact",
      "affectedAreas",
      "affectedFiles",
      "dependencies",
      "risks",
      "riskLevel",
      "requiredChecks",
      "acceptanceCriteria",
      "sources",
      "recommendation",
      "ownerDecisionRequired",
      "suggestedPipelineStep",
      "noRuntimeChanges",
      "noRunnerStarted",
      "noBranchOrPrOrMerge",
      "noDeploy",
      "noTokenPaymentBlockchain"
    ]
  },
  "githubBuilderExecutionContractV1": {
    "purpose": "Controlled owner/admin-only GitHub Builder v1 contract for preparing only a branch/PR plan or branch/PR after guards; never merge/deploy.",
    "callable": "prepareGithubBuilderBranchPrFromWorkPackage",
    "serialGroup": "main_repo",
    "baseBranch": "main",
    "maxConcurrentInSerialGroup": 1,
    "maxRepairAttempts": 3,
    "requiredFields": [
      "workPackageId",
      "sourceDossierId",
      "sourceDossierType",
      "ownerDecisionId",
      "ownerApproved",
      "ownerDecisionPersistent",
      "approvedForSerialExecution",
      "serialGroup",
      "executionOrder",
      "baseBranch",
      "baseSha",
      "branchName",
      "prTitle",
      "prBody",
      "allowedFiles",
      "blockedFiles",
      "requiredChecks",
      "maxRepairAttempts",
      "repairAttemptCount",
      "reapprovalRequired",
      "reapprovalReason",
      "noParallelExecution",
      "noAutoMerge",
      "noAutoDeploy",
      "noTokenPaymentBlockchain",
      "noCanonicalTruthAutonomousChange",
      "noFirestoreRulesChangeUnlessExplicitlyAllowed",
      "noRuntimeRewardLedgerAntiCheatChangeUnlessExplicitlyAllowed"
    ],
    "statuses": [
      "branch_pr_plan_created",
      "branch_created",
      "pr_created",
      "checks_pending",
      "checks_passed",
      "checks_failed",
      "repair_attempt_1",
      "repair_attempt_2",
      "repair_attempt_3",
      "repair_required",
      "ready_for_owner_merge_decision",
      "blocked_by_guard",
      "blocked_by_missing_github_credentials",
      "blocked_by_protected_files",
      "blocked_by_reapproval_required"
    ],
    "guardrails": {
      "noAutoMerge": true,
      "noAutoDeploy": true,
      "noTokenPaymentBlockchain": true,
      "noCanonicalTruthAutonomousChange": true,
      "noFirestoreRulesChangeUnlessExplicitlyAllowed": true,
      "noRuntimeRewardLedgerAntiCheatChangeUnlessExplicitlyAllowed": true
    }
  }
}
