{
  "schemaId": "wellfit.agent-dossier.minimum-fields.v1",
  "purpose": "Shared minimum field contract for Safety, Agent, Mission, and Research dossiers shown in the Admin Center.",
  "minimumFields": [
    "title",
    "shortSummary",
    "plainLanguageSummary",
    "problem",
    "proposedChange",
    "whyNow",
    "wellfitBenefit",
    "userBenefit",
    "financialBenefit",
    "internalEconomyImpact",
    "risks",
    "riskLevel",
    "affectedAreas",
    "affectedFiles",
    "requiredChecks",
    "sources",
    "recommendation",
    "ownerDecisionRequired",
    "nextPipelineStep",
    "noRuntimeChanges",
    "noTokenPaymentBlockchain",
    "noRunnerStarted",
    "noBranchOrPrOrMerge",
    "noDeploy"
  ],
  "guardrails": {
    "noRuntimeChangesDefault": true,
    "noTokenPaymentBlockchainDefault": true,
    "noRunnerStartedDefault": true,
    "noBranchOrPrOrMergeDefault": true,
    "noDeployDefault": true,
    "metadataOnlyUntilOwnerApproval": true,
    "persistentOwnerDecisionUntilReapprovalGuard": true,
    "serialBuilderExecutionGroup": "main_repo",
    "maxConcurrentInSerialGroup": 1
  },
  "approvedBuilderBacklogFields": [
    "ownerDecisionId",
    "ownerDecisionStatus",
    "ownerDecisionPersistent",
    "approvedForSerialExecution",
    "reapprovalRequired",
    "reapprovalReason",
    "lastRevalidatedAt",
    "revalidationStatus",
    "staleAfterMainSha",
    "sourceMainShaAtApproval",
    "currentMainShaAtLastValidation",
    "executionOrder",
    "serialGroup",
    "maxConcurrentInSerialGroup"
  ],
  "verificationPlanFields": [
    "verificationRequired",
    "verificationStatus",
    "verificationChecklist",
    "postMergeChecks",
    "adminSnapshotRequired",
    "uiSmokeSnapshotRequired",
    "lastVerificationAt",
    "verificationFailureReason",
    "createsRepairDossierOnFailure"
  ],
  "conversationIdeaDossier": {
    "collection": "agentConversationIdeaDossiers",
    "callable": "createConversationIdeaDossier",
    "sourceValues": [
      "chat",
      "admin_note",
      "uploaded_transcript",
      "manual"
    ],
    "ownerDecisionRequiredDefault": true,
    "metadataOnly": true,
    "sanitizing": [
      "redact_private_emails",
      "redact_tokens_secrets_sessions",
      "truncate_large_text",
      "no_personal_payloads"
    ],
    "outputFields": [
      "dossierId",
      "title",
      "shortSummary",
      "plainLanguageSummary",
      "problem",
      "proposedChange",
      "whyNow",
      "wellfitBenefit",
      "userBenefit",
      "financialBenefit",
      "internalEconomyImpact",
      "affectedAreas",
      "affectedFiles",
      "dependencies",
      "risks",
      "riskLevel",
      "requiredChecks",
      "acceptanceCriteria",
      "sources",
      "recommendation",
      "ownerDecisionRequired",
      "suggestedPipelineStep",
      "noRuntimeChanges",
      "noRunnerStarted",
      "noBranchOrPrOrMerge",
      "noDeploy",
      "noTokenPaymentBlockchain"
    ]
  }
}
