    "node scripts/wellfit-dev-agent/src/pr-review-policy-check.mjs",
    "jq empty project-register/pr-review-policy.json",
    "node scripts/wellfit-dev-agent/src/task-status-work-log-check.mjs",
    "jq empty project-register/task-status-policy.json",
    "node scripts/wellfit-dev-agent/src/pr-post-creation-guard-check.mjs",
    "jq empty project-register/pr-post-creation-guard.json",
    "node scripts/wellfit-dev-agent/src/pr-diff-review-report.mjs",
    "jq empty project-register/pr-diff-review-policy.json",
    "node scripts/wellfit-dev-agent/src/batch-execution-runner-check.mjs",
    "jq empty project-register/batch-execution-runner-policy.json",
    "node scripts/wellfit-dev-agent/src/website-agent-framework-check.mjs",
    "jq empty project-register/website-agents.json",
    "jq empty project-register/website-readiness.json",
    "node scripts/wellfit-dev-agent/src/continuity-dependency-check.mjs",
    "jq empty project-register/continuity-dependency-map.json",
    "node scripts/wellfit-dev-agent/src/website-agent-backlog-check.mjs",
    "jq empty project-register/website-agent-backlog.json",
    "node scripts/wellfit-dev-agent/src/agent-extension-policy-check.mjs"
  ],
  "riskGates": {
    "sourceOfTruth": "project-register/risk-classifier.json",
    "allowedAutomaticSelectionRiskLevels": [
      "low",
      "medium"
    ],
    "implementationAllowedByAutopilotDryRun": false,
    "low": {
      "defaultAction": "planning_or_documentation_registry_script_work_after_normal_agent_plan",
      "dryRunAction": "report_only"
    },
    "medium": {
      "defaultAction": "planning_only_unless_human_explicitly_requests_scoped_runtime_work",
      "dryRunAction": "report_only"
    },
    "high": {
      "defaultAction": "stop_and_report_for_human_approval",
      "dryRunAction": "stop_before_implementation"
    },
    "critical": {
      "defaultAction": "stop_and_report_for_human_approval",
      "dryRunAction": "stop_before_implementation"
    },
    "defaultWhenUnclear": "high"
  },
  "requiredReportOutput": [
    "activation_state",
    "selected_next_safe_task",
    "selection_source_and_rationale",
    "task_selection_memory_and_recently_completed_skip",
    "risk_classification",
    "implementation_allowed_or_planning_only",
    "definition_of_done_key_and_evidence",
    "required_checks",
    "affected_registers_and_files",
    "forbidden_files_and_actions",
    "stop_conditions",
    "product_readiness_context",
    "research_recommendation_context_when_present",
    "adaptive_user_insight_context_when_present",
    "no_merge_no_deploy_reminder",
    "human_approval_rule",
    "auto_merge_eligibility_report_only_result",
    "auto_repair_decision_report_only_result",
    "pr_review_policy_report_only_result",
    "task_status_sync_ready_result",
    "confirmation_no_task_status_auto_rewrites",
    "pr_post_creation_guard_report_only_result",
    "post_pr_mergeability_and_required_checks_next_action"
  ],
  "humanApprovalRules": {
    "requiredForRiskLevels": [
      "high",
      "critical"
    ],
    "requiredForProtectedTopics": true,
    "requiredForMerge": true,
    "requiredForDeploy": true,
    "requiredForRuntimeProductLogicChangeFromAutopilot": true,
    "requiredForComplianceCriticalLogic": true,
    "requiredForUnityOrPr13": true,
    "unclearRiskDefaultsToApprovalRequired": true
  },
  "noMergeNoDeployRule": {
    "mergeAllowed": false,
    "deployAllowed": false,
    "message": "Autopilot prepares a report and PR handoff only; it never merges or deploys."
  },
  "taskSelectionMemoryRule": "[object Object] After every selected task, map the work to project-register/cross-reference-maintenance.json categories and inspect/update the required cross-reference files before closing the PR.",
  "batchAutopilotDryRunReference": {
    "policy": "project-register/autopilot-batch-policy.json",
    "architecture": "docs/architecture/WELLFIT_AUTOPILOT_BATCH_MODE.md",
    "script": "scripts/wellfit-dev-agent/src/autopilot-batch-dry-run.mjs",
    "activationState": "dry_run_only",
    "scope": "report-only multi-task planning for low-risk documentation/register/governance/inventory/analysis tasks",
    "neverDoes": [
      "write_files",
      "create_pull_requests",
      "merge",
      "deploy",
      "repair_files",
      "approve_own_work"
    ]
  },
  "batchAutopilotLimitedExecutionReference": {
    "policy": "project-register/autopilot-batch-execution-policy.json",
    "architecture": "docs/architecture/WELLFIT_AUTOPILOT_BATCH_LIMITED_EXECUTION.md",
    "script": "scripts/wellfit-dev-agent/src/autopilot-batch-limited-execution-check.mjs",
    "mode": "report_check_only_planning",
    "mustNotExecuteTasks": true,
    "mustNotCreatePullRequests": true,
    "mustNotMerge": true,
    "mustNotRepair": true,
    "mustNotDeploy": true
  },
  "batchExecutionRunnerReference": {
    "policy": "project-register/batch-execution-runner-policy.json",
    "architecture": "docs/architecture/WELLFIT_BATCH_EXECUTION_RUNNER.md",
    "script": "scripts/wellfit-dev-agent/src/batch-execution-runner-check.mjs",
    "mode": "framework_only_report_check",
    "mustNotExecuteTasks": true,
    "mustNotCreatePullRequests": true,
    "mustNotMerge": true,
    "mustNotRepair": true,
    "mustNotDeploy": true
  },
  "continuityDependencySentinelReference": {
    "map": "project-register/continuity-dependency-map.json",
    "architecture": "docs/architecture/WELLFIT_CONTINUITY_DEPENDENCY_SENTINEL.md",
    "check": "scripts/wellfit-dev-agent/src/continuity-dependency-check.mjs",
    "mode": "report_only",
    "purpose": "Preserve open dependencies, blocked/review-required handoffs, and required next output files before selecting automation or next-agent work."
  },
  "agentExtensionPolicyReference": {
    "policy": "project-register/agent-extension-policy.json",
    "architecture": "docs/architecture/WELLFIT_AGENT_EXTENSION_POLICY.md",
    "script": "scripts/wellfit-dev-agent/src/agent-extension-policy-check.mjs",
    "activationState": "report_only",
    "rule": "Autopilot may extend existing agents only when the capability clearly fits one existing owner; new agent names, registers, workflow families, protected scope, runtime authority, auto-merge, auto-repair, deployment, or self-approval require a proposal and human review first.",
    "neverDoes": [
      "create agents automatically",
      "create agent registers automatically",
      "approve PRs",
      "merge PRs",
      "repair files",
      "deploy",
      "touch runtime/protected/Unity/PR #13 areas"
    ]
  }
}
