  "iterationPhases": [
    {
      "id": "read_memory",
      "purpose": "Read repository instructions, current state, work map, TODO index, next actions, workflow registers, task queue, risk classifier, definition of done, work log, readiness, internal sources, roadmap, feedback, insights, and research registers before planning changes."
    },
    {
      "id": "inspect_current_state",
      "purpose": "Inspect branch, worktree, dependency state, mapped leading files, and whether the task is documentation/registry/script-only or runtime product work."
    },
    {
      "id": "select_next_task",
      "purpose": "Use the existing task queue, progress-log/agent-work-log memory, and next-task suggestion logic to identify the safest non-blocked low/medium-risk task without immediately repeating a just-completed task unless no other safe candidate exists."
    },
    {
      "id": "classify_risk",
      "purpose": "Classify the requested or selected task with project-register/risk-classifier.json; default unclear or protected work to high or critical and stop before implementation."
    },
    {
      "id": "check_definition_of_done",
      "purpose": "Verify the task has a valid definitionOfDoneKey and required evidence/check mappings in project-register/definition-of-done.json."
    },
    {
      "id": "inspect_related_files",
      "purpose": "Inspect existing leading files from the Work Map, TODO index, internal sources, readiness matrix, roadmap, feedback, research, and insight registers without creating duplicate architecture or parallel systems."
    },
    {
      "id": "create_plan",
      "purpose": "Create a small report-only plan listing allowed files, forbidden files, required checks, risk gates, expected evidence, and stop conditions."
    },
    {
      "id": "run_validation_checks",
      "purpose": "Run validation/report-only checks required by the selected task, definition of done, and Autopilot governance; the dry-run script itself never writes files."
    },
    {
      "id": "report_followups",
      "purpose": "Report follow-ups from existing registers and report-only scripts; do not auto-create high/critical follow-ups or new TODO systems."
    },
    {
      "id": "prepare_pr_summary",
      "purpose": "Prepare the PR handoff summary with changed files, checks, risks, skipped checks, dependency status, and next recommended task."
    },
    {
      "id": "stop_for_human_approval",
      "purpose": "Stop before merge, deploy, protected implementation, high/critical work, or any approval-required action."
    }
  ],
  "allowedActions": [
    "read_existing_governance_todo_architecture_and_project_register_files",
    "run_validation_and_report_only_scripts",
    "call_suggest_next_agent_task_for_task_selection",
    "print_selected_safe_task_risk_required_checks_affected_files_and_stop_conditions",
    "prepare_human_readable_plan_and_pr_handoff",
    "update_autopilot_governance_docs_or_registers_only_when_explicitly_requested_by_human_task_outside_the_dry_run_script",
    "run_auto_merge_eligibility_check_report_only",
    "run_batch_autopilot_dry_run_report_only_for_multi_task_planning",
    "run_pr_review_policy_check_report_only",
    "run_task_status_work_log_sync_check_report_only"
  ],
  "forbiddenActions": [
    "write_files_automatically_from_agent_autopilot_dry_run",
    "merge_deploy_publish_or_close_pull_requests",
    "touch_pr_13_or_native_unity_wellfitbuddyar_files",
    "modify_runtime_product_logic_for_documentation_registry_script_only_tasks",
    "create_duplicate_architecture_task_systems_registries_routes_apis_or_feature_modules",
    "modify_token_nft_wallet_payment_payout_marketplace_staking_presale_trading_or_betting_logic_without_explicit_human_approval",
    "modify_reward_authority_final_ledger_mission_completion_anticheat_inventory_unlock_or_rare_item_authority_without_explicit_human_approval",
    "modify_health_watch_child_location_camera_privacy_consent_medical_legal_agb_datenschutz_impressum_or_compliance_logic_without_explicit_human_approval",
    "expose_secrets_or_server_api_keys",
    "enable_or_perform_real_auto_merge_without_explicit_human_approval",
    "run_auto_repair_loops_from_report_only_policy",
    "enable_or_perform_real_auto_repair_without_explicit_human_approval",
    "enable_real_batch_execution_without_explicit_human_approval",
    "create_pull_requests_merge_deploy_or_repair_from_batch_autopilot_dry_run",
    "approve_batch_autopilot_output_as_its_own_review",
    "enable_or_perform_real_batch_execution_without_explicit_human_approval",
    "create_pull_requests_from_batch_limited_execution_check",
    "treat_limited_execution_readiness_as_human_approval",
    "enable_or_perform_real_pr_auto_approval_without_explicit_human_approval",
    "treat_pr_review_policy_ready_as_merge_approval",
    "rewrite_todo_statuses_automatically_from_task_status_validator",
    "enable_auto_merge_or_auto_repair_from_task_status_validator",
    "use_pr_diff_review_as_merge_approval",
    "use_pr_diff_review_as_auto_repair_authorization",
    "enable_or_perform_website_runtime_changes_from_website_agent_framework",
    "treat_website_readiness_as_human_legal_privacy_health_child_token_payment_reward_or_investor_approval",
    "create_new_agent_without_agent_extension_policy_proposal",
    "create_new_agent_register_without_human_review",
    "create_new_workflow_family_without_human_review"
  ],
  "stopConditions": [
    "current_branch_is_main",
    "risk_level_is_high_or_critical",
    "risk_level_is_unclear",
    "protected_topic_detected",
    "task_requires_files_outside_allowed_mapped_files",
    "runtime_product_logic_change_required_for_documentation_registry_script_only_task",
    "would_create_duplicate_architecture_or_parallel_system",
    "required_governance_file_missing_or_malformed",
    "definition_of_done_key_missing",
    "validation_check_fails_for_code_reason",
    "human_approval_required_but_not_present",
    "auto_merge_policy_activation_state_is_not_report_only",
    "auto_repair_policy_not_report_only",
    "auto_repair_decision_requires_forbidden_path_topic_or_runtime_product_change",
    "batch_autopilot_policy_activation_state_is_not_dry_run_only",
    "batch_autopilot_candidate_touches_forbidden_path_or_topic",
    "batch_autopilot_would_write_create_pr_merge_deploy_repair_or_approve_work",
    "batch_limited_execution_policy_activation_state_is_not_limited_execution_planning",
    "batch_limited_execution_would_execute_create_pr_merge_repair_deploy_or_self_approve",
    "pr_review_policy_activation_state_is_not_report_only",
    "pr_review_policy_would_approve_merge_repair_deploy_or_modify_files"
  ],
  "requiredChecks": [
    "npm run lint",
    "npx tsc --noEmit",
    "npm run build",
    "npm --prefix functions run check",
    "npm run agent:quality-gate",
