{
  "version": "0.1.0",
  "updated": "2026-05-15",
  "purpose": "Report-only guardrail policy for determining whether a future WellFit pull request would be eligible for automatic merge consideration. This policy never authorizes or performs a merge by itself.",
  "activationState": "report_only",
  "allowedAutoMergeCategories": [
    "documentation_baseline",
    "registry_sync",
    "agent_governance_docs",
    "progress_log_update",
    "repository_inventory_mapping"
  ],
  "forbiddenAutoMergePaths": [
    "app/**",
    "components/**",
    "lib/**",
    "functions/**",
    "firestore.rules",
    "native/unity/WellFitBuddyAR/**",
    "package.json unless explicitly approved",
    "package-lock.json unless explicitly approved"
  ],
  "forbiddenAutoMergeTopics": [
    "token",
    "NFT",
    "wallet",
    "payment",
    "betting",
    "reward authority",
    "mission completion authority",
    "health",
    "child",
    "location",
    "privacy",
    "legal",
    "compliance",
    "Unity",
    "PR #13"
  ],
  "requiredChecks": [
    "npm run lint",
    "npx tsc --noEmit",
    "npm run build",
    "npm --prefix functions run check",
    "npm run agent:quality-gate",
    "node scripts/wellfit-dev-agent/src/auto-merge-eligibility-check.mjs",
    "jq empty project-register/auto-merge-policy.json",
    "npm run agent:autopilot:dry-run"
  ],
  "requiredPRState": {
    "draft": false,
    "mergeConflicts": false,
    "allRequiredChecksPassed": true,
    "branchUpToDateWithBase": true,
    "reviewDecision": "approved_or_human_reviewed",
    "humanReviewRequiredWhenIneligible": true,
    "realAutoMergeEnabled": false
  },
  "humanApprovalAlwaysRequiredFor": [
    "any activationState other than report_only",
    "any forbiddenAutoMergePath match",
    "any forbiddenAutoMergeTopic match",
    "any package.json or package-lock.json change without explicit approval",
    "any runtime product code change",
    "any app, component, lib, function, Firestore rules, or Unity/WellFitBuddyAR change",
    "token, NFT, wallet, payment, betting, reward authority, mission completion authority, health, child, location, privacy, legal, compliance, Unity, or PR #13 topics",
    "high or critical risk classifications",
    "failed, missing, skipped, or unknown required checks",
    "more changed files, additions, or deletions than the configured maximum"
  ],
  "maxChangedFilesForAutoMerge": 8,
  "maxAdditionsForAutoMerge": 400,
  "maxDeletionsForAutoMerge": 200,
  "reportOutputSchema": {
    "activationState": "string",
    "autoMergeEligible": "boolean",
    "autoMergeEligibleLine": "AUTO_MERGE_ELIGIBLE=true|false",
    "reasons": ["string"],
    "changedFiles": ["string"],
    "changedFileCount": "number",
    "additions": "number",
    "deletions": "number",
    "docsRegistryOnly": "boolean",
    "forbiddenPathMatches": [
      {
        "file": "string",
        "pattern": "string"
      }
    ],
    "forbiddenTopicMatches": [
      {
        "topic": "string",
        "file": "string",
        "source": "path_or_diff"
      }
    ],
    "requiredChecks": ["string"],
    "requiredChecksListed": "boolean",
    "neverMerges": true
  }
}
