{
  "agentName": "wellfit-dev-agent",
  "version": "0.3.2",
  "mode": "dry-run",
  "repository": "Bernds-tech/WellFit-now",
  "sourceOfTruth": [
    "todolist/README.md",
    "todolist/J - NÄCHSTE EMPFOHLENE ARBEIT",
    "todolist/CHAT_START_PROMPT.md",
    "todolist/AUTONOMOUS_ITERATION_MODE.md",
    "docs/architecture/WELLFIT_ALPHA_SCOPE_CUT.md"
  ],
  "topicFiles": {
    "mobileArBuddy": [
      "todolist/H - MOBILE - AR - TRACKING - KI",
      "todolist/H1 - NATIVE AR - ARCORE - ARKIT - UNITY",
      "todolist/H2 - BUDDY ALS REALER AR-BEGLEITER UND KI-GUIDE",
      "todolist/K_AR-BUDDY_COMPANION_UND_AVATAR-GRUNDLOGIK.md"
    ],
    "rewardsEconomy": [
      "todolist/F - FIREBASE  - REALTIME - MISSIONEN",
      "todolist/G - REWARD SYSTEM - SYSTEM HEALTH - NEXT-GEN MECHANICS",
      "todolist/G1 - INTERNE PUNKTEOEKONOMIE VOR BLOCKCHAIN",
      "docs/architecture/MISSION_REWARD_CONTEXT_ENGINE.md"
    ],
    "businessWebsiteLegal": [
      "todolist/I - BUSINESS - WEBSITE - PARTNER - LEGAL"
    ],
    "agentArchitecture": [
      "docs/architecture/WELLFIT_SELF_HOSTED_DEV_AGENT.md",
      "docs/architecture/WELLFIT_ADAPTIVE_MISSION_INSIGHT_AGENT.md",
      "docs/architecture/WELLFIT_ALPHA_SCOPE_CUT.md"
    ]
  },
  "defaultTopic": "agentArchitecture",
  "outputPath": "scripts/wellfit-dev-agent/output/dry-run-report.md",
  "coderPromptOutputDir": "scripts/wellfit-dev-agent/output/coder-prompts",
  "maxOpenTasksPerFile": 12,
  "maxPlannedMicroTasks": 12,
  "identityGate": {
    "enabled": true,
    "requiredQuestion": "Bevor du am Code oder auf GitHub weitermachst: Welcher Coder bist du? Antworte exakt mit deiner registrierten Rolle, zum Beispiel: Coder 1, Coder 2, Coder 3 ...",
    "rejectUnknownIdentity": true,
    "unknownIdentityMessage": "Ich kann noch keine Aufgabe zuweisen. Bitte nenne zuerst deine registrierte Rolle, z. B. Coder 1, Coder 2, Coder 3 usw."
  },
  "todoMutationPolicy": {
    "enabled": true,
    "allowDeleteTodoEntries": false,
    "allowDeleteRoadmapSections": false,
    "allowedMutations": [
      "changeStatusMarker",
      "changePriority",
      "appendClarification",
      "appendNewTask",
      "moveToBacklogWithMarker",
      "addRiskNote",
      "addBuildNote",
      "addReviewNote"
    ],
    "protectedGlobs": [
      "todolist/**",
      "docs/architecture/**"
    ],
    "requiredNote": "Bestehende ToDo-/Roadmap-Einträge dürfen nicht gelöscht werden. Der Agent darf nur Status/Priorität ändern, ergänzen, erweitern oder mit [>] in Backlog verschieben."
  },
  "alphaScope": {
    "enabled": true,
    "priorityKeywords": [
      "alpha",
      "beta",
      "mobile",
      "ar",
      "unity",
      "android",
      "buddy",
      "mission",
      "challenge",
      "punkte",
      "xp",
      "reward",
      "completion",
      "firebase",
      "backend",
      "security",
      "rules",
      "login",
      "registrierung",
      "profil",
      "deployment",
      "datenschutz",
      "app-store",
      "test",
      "qa",
      "debug"
    ],
    "backlogKeywords": [
      "nft",
      "token",
      "wft",
      "blockchain",
      "marketplace",
      "trading",
      "staking",
      "dao",
      "depin",
      "compute",
      "whitelabel",
      "b2b",
      "voice wake",
      "wake word",
      "vererbung",
      "lebenslanger avatar",
      "partnerplattform",
      "museum",
      "städte",
      "stadt",
      "pharma"
    ]
  },
  "coderAssignment": {
    "enabled": true,
    "dynamicRegistry": true,
    "rebalanceOnRegistryChange": true,
    "coders": [
      {
        "id": "coder1",
        "displayName": "Coder 1",
        "selfNames": ["coder 1", "coder1", "c1"],
        "role": "Mobile / AR / Buddy / Unity",
        "focusKeywords": ["mobile", "ar", "unity", "android", "buddy", "avatar", "kamera", "camera", "debug", "qa"],
        "avoidKeywords": ["reward", "punkte", "xp", "completion", "firestore rules", "token", "nft"]
      },
      {
        "id": "coder2",
        "displayName": "Coder 2",
        "selfNames": ["coder 2", "coder2", "c2"],
        "role": "Backend / Firebase / Mission Completion / Security",
        "focusKeywords": ["backend", "firebase", "firestore", "rules", "functions", "serverseitig", "completion", "reward", "punkte", "xp", "ledger", "mission", "security", "emulator"],
        "avoidKeywords": ["nft", "token", "trading", "marketplace", "depin"]
      },
      {
        "id": "coder3",
        "displayName": "Coder 3",
        "selfNames": ["coder 3", "coder3", "c3"],
        "role": "Website / UX / QA / Datenschutz / Dokumentation / Agent",
        "focusKeywords": ["website", "business", "legal", "datenschutz", "app-store", "ux", "ui", "qa", "test", "doku", "documentation", "agent", "prompt", "deployment"],
        "avoidKeywords": ["reward", "completion", "anti-cheat", "firestore rules", "token", "nft"]
      }
    ],
    "defaultCoderId": "coder3",
    "maxTasksPerCoder": 4
  },
  "writePolicy": {
    "dryRunCanWriteReport": true,
    "canModifyCode": false,
    "canCreateBranch": false,
    "canCreatePullRequest": false,
    "canDeployProduction": false
  },
  "protectedAreas": [
    "firestore.rules",
    "functions/**",
    "app/api/**",
    "lib/**reward**",
    "lib/**mission**",
    "lib/**economy**",
    "lib/**antiCheat**",
    "app/mobile/**",
    "app/missionen/**"
  ],
  "blockedAutonomousActions": [
    "authorizeRewards",
    "authorizePoints",
    "authorizeXp",
    "authorizeMissionCompletion",
    "modifyAntiCheatDecision",
    "modifyJackpotSettlement",
    "addMobileTokenTrading",
    "writeSecretsToFrontend",
    "deployProduction",
    "deleteTodoEntries",
    "deleteRoadmapSections"
  ]
}
