rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isReadableByOwnerUserId() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isReadableByOwnerOrGuardian() {
      return isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.ownerUserId == request.auth.uid ||
        resource.data.reporterUserId == request.auth.uid ||
        resource.data.guardianUserId == request.auth.uid ||
        (resource.data.guardianUserIds is list && resource.data.guardianUserIds.hasAny([request.auth.uid]))
      );
    }

    // Safe owner-writable MVP profile fields.
    // These may remain client-writable after the economy hardening step if they do not
    // authorize points, XP, level, rewards, mission completion or anti-cheat decisions.
    function hasOnlySafeUserProfileKeys() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'updatedAt',
        'lastLoginAt',
        'profile',
        'settings',
        'consent',
        'inventory'
      ]);
    }

    // Temporary MVP bridge fields.
    // These must become server-only after the server ledger / projection path is active:
    // RewardPreview -> Completion -> Ledger/Audit -> UserStats/UserAvatar projection.
    function hasOnlyTemporaryEconomyBridgeKeys() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'points',
        'avatar',
        'lastMissionCompletedAt',
        'xp',
        'level',
        'stepsToday',
        'energy',
        'deviceLocation'
      ]);
    }

    // Current beta compatibility rule.
    // Do not harden this to safe profile keys only until Dashboard, Tagesmissionen and
    // Buddy sinks write through a server-only ledger/projection path.
    function hasOnlyUserWritableKeys() {
      return hasOnlySafeUserProfileKeys() || hasOnlyTemporaryEconomyBridgeKeys();
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && hasOnlyUserWritableKeys();
      allow delete: if false;
    }

    // Temporary MVP bridge: daily mission UI state is still owner-writable.
    // Target: server projection / completion state after ledger persistence is active.
    match /userDailyMissionState/{stateId} {
      allow read, write: if isSignedIn() && stateId.matches(request.auth.uid + '_.*');
    }

    // Temporary MVP bridge: streaks are still owner-writable.
    // Target: derive from server-authorized mission completion ledger events.
    match /userDailyStreaks/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Temporary MVP bridge: levels are still owner-writable.
    // Target: derive from server-authorized XP ledger events.
    match /userLevels/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /missionBuddyEvents/{eventId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /trackingSessions/{sessionId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /trackingProofEvents/{proofEventId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /missionContextEvaluations/{evaluationId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /missionCompletionEvaluations/{evaluationId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /missionRewardPreviews/{previewId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /missionEvidenceReviews/{reviewId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /missionPatternReviews/{reviewId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /missionCooldownReviews/{reviewId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /missionRewardPolicies/{policyId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /systemReserveSnapshots/{snapshotId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /missionRewardEvents/{rewardEventId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    // Server-only economy authority collections prepared in Mega-Block 21.
    // Clients may read their own records for transparency, but must never create,
    // update or delete these records. Future server writes must use Admin/server code.
    match /ledgerEvents/{ledgerEventId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /auditEvents/{auditEventId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /userEconomyProjections/{projectionId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /pointsSinkEvents/{sinkEventId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /itemDefinitions/{itemId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /userInventory/{inventoryItemId} {
      allow read: if isSignedIn() && resource.data.ownerUserId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /buddyCapabilities/{capabilityDocId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /nfcTags/{tagId} {
      allow read, write: if false;
    }

    match /nfcScanEvents/{scanEventId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /nfcScanClaims/{claimId} {
      allow read, write: if false;
    }

    match /capabilityUnlockEvents/{eventId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }

    match /buddyItemUseEvents/{eventId} {
      allow read: if isReadableByOwnerUserId();
      allow create, update, delete: if false;
    }


    // Beta 1 runtime authority: clients may read only scoped records or published
    // definitions. All protected XP, mission, shop, inventory, mayor, glitch and
    // admin decisions are written by Firebase Admin SDK callable functions only.
    match /familyAccounts/{familyAccountId} {
      allow read: if isSignedIn() && resource.data.guardianUserIds.hasAny([request.auth.uid]);
      allow create, update, delete: if false;
    }

    match /childProfiles/{childProfileId} {
      allow read: if isSignedIn() && resource.data.guardianUserIds.hasAny([request.auth.uid]);
      allow create, update, delete: if false;
    }

    match /guardianChildLinks/{linkId} {
      allow read: if isSignedIn() && resource.data.guardianUserId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /parentalConsents/{consentId} {
      allow read: if isSignedIn() && resource.data.guardianUserId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /avatarDefinitions/{definitionId} {
      allow read: if isSignedIn() && resource.data.status == 'published';
      allow create, update, delete: if false;
    }

    match /userAvatars/{avatarId} {
      allow read: if isReadableByOwnerOrGuardian();
      allow create, update, delete: if false;
    }

    match /avatarXpEvents/{eventId} {
      allow read: if isReadableByOwnerOrGuardian();
      allow create, update, delete: if false;
    }

    match /regions/{regionId} {
      allow read: if isSignedIn() && resource.data.betaEnabled == true;
      allow create, update, delete: if false;
    }

    match /missionLocations/{locationId} {
      allow read: if isSignedIn() && resource.data.safeLocationStatus == 'approved';
      allow create, update, delete: if false;
    }

    match /missions/{missionId} {
      allow read: if isSignedIn() && resource.data.status == 'published';
      allow create, update, delete: if false;
    }

    match /missionAttempts/{attemptId} {
      allow read: if isReadableByOwnerOrGuardian();
      allow create, update, delete: if false;
    }

    match /missionEvidence/{evidenceId} {
      allow read: if isReadableByOwnerOrGuardian();
      allow create, update, delete: if false;
    }

    match /missionCompletions/{completionId} {
      allow read: if isReadableByOwnerOrGuardian();
      allow create, update, delete: if false;
    }

    match /xpWallets/{walletId} {
      allow read: if isReadableByOwnerOrGuardian();
      allow create, update, delete: if false;
    }

    match /xpLedgerEvents/{eventId} {
      allow read: if isReadableByOwnerOrGuardian();
      allow create, update, delete: if false;
    }

    match /xpRewardPolicies/{policyId} {
      allow read: if isSignedIn() && resource.data.status == 'active';
      allow create, update, delete: if false;
    }

    match /shopItems/{shopItemId} {
      allow read: if isSignedIn() && resource.data.status == 'published';
      allow create, update, delete: if false;
    }

    match /shopPurchaseIntents/{intentId} {
      allow read: if isReadableByOwnerOrGuardian();
      allow create, update, delete: if false;
    }

    match /shopPurchaseEvents/{eventId} {
      allow read: if isReadableByOwnerOrGuardian();
      allow create, update, delete: if false;
    }

    match /checkpoints/{checkpointId} {
      allow read: if isSignedIn() && resource.data.status == 'published';
      allow create, update, delete: if false;
    }

    match /checkpointScores/{scoreId} {
      allow read: if isReadableByOwnerOrGuardian();
      allow create, update, delete: if false;
    }

    match /checkpointMayors/{mayorId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /mayorShareEvents/{eventId} {
      allow read: if isSignedIn() && resource.data.mayorUserId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /glitchEvents/{glitchEventId} {
      allow read: if isSignedIn() && resource.data.status == 'active';
      allow create, update, delete: if false;
    }

    match /glitchParticipants/{participantId} {
      allow read: if isReadableByOwnerOrGuardian();
      allow create, update, delete: if false;
    }

    match /glitchBoostWindows/{boostWindowId} {
      allow read: if isReadableByOwnerOrGuardian();
      allow create, update, delete: if false;
    }

    match /glitchSafetyRules/{ruleId} {
      allow read, write: if false;
    }

    match /safetyReports/{reportId} {
      allow read: if isReadableByOwnerOrGuardian();
      allow create, update, delete: if false;
    }


    function hasAgentAdminReadRole() {
      return isSignedIn() && request.auth.token.agentRole in ["owner", "admin_operator", "agent_supervisor", "readonly_observer", "support_operator", "agent_executor_service"];
    }

    match /adminActions/{actionId} {
      allow read, write: if false;
    }


    match /agentTaskProposals/{docId} {
      allow read: if hasAgentAdminReadRole();
      allow create, update, delete: if false;
    }

    match /agentTaskApprovals/{docId} {
      allow read: if hasAgentAdminReadRole();
      allow create, update, delete: if false;
    }

    match /agentTaskExecutions/{docId} {
      allow read: if hasAgentAdminReadRole();
      allow create, update, delete: if false;
    }

    match /agentTaskAuditLog/{docId} {
      allow read: if hasAgentAdminReadRole();
      allow create, update, delete: if false;
    }

    match /agentTaskCheckResults/{docId} {
      allow read: if hasAgentAdminReadRole();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
