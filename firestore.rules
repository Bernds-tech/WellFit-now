rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Safe owner-writable MVP profile fields.
    // These may remain client-writable after the economy hardening step if they do not
    // authorize points, XP, level, rewards, mission completion or anti-cheat decisions.
    function hasOnlySafeUserProfileKeys() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'updatedAt',
        'lastLoginAt',
        'profile',
        'settings',
        'consent',
        'inventory'
      ]);
    }

    // Temporary MVP bridge fields.
    // These must become server-only after the server ledger / projection path is active:
    // RewardPreview -> Completion -> Ledger/Audit -> UserStats/UserAvatar projection.
    function hasOnlyTemporaryEconomyBridgeKeys() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'points',
        'avatar',
        'lastMissionCompletedAt',
        'xp',
        'level',
        'stepsToday',
        'energy',
        'deviceLocation'
      ]);
    }

    // Current beta compatibility rule.
    // Do not harden this to safe profile keys only until Dashboard, Tagesmissionen and
    // Buddy sinks write through a server-only ledger/projection path.
    function hasOnlyUserWritableKeys() {
      return hasOnlySafeUserProfileKeys() || hasOnlyTemporaryEconomyBridgeKeys();
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && hasOnlyUserWritableKeys();
      allow delete: if false;
    }

    // Temporary MVP bridge: daily mission UI state is still owner-writable.
    // Target: server projection / completion state after ledger persistence is active.
    match /userDailyMissionState/{stateId} {
      allow read, write: if isSignedIn() && stateId.matches(request.auth.uid + '_.*');
    }

    // Temporary MVP bridge: streaks are still owner-writable.
    // Target: derive from server-authorized mission completion ledger events.
    match /userDailyStreaks/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Temporary MVP bridge: levels are still owner-writable.
    // Target: derive from server-authorized XP ledger events.
    match /userLevels/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /missionBuddyEvents/{eventId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /trackingSessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /trackingProofEvents/{proofEventId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /missionContextEvaluations/{evaluationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /missionCompletionEvaluations/{evaluationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /missionRewardPreviews/{previewId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /missionEvidenceReviews/{reviewId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /missionPatternReviews/{reviewId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /missionCooldownReviews/{reviewId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /missionRewardPolicies/{policyId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /systemReserveSnapshots/{snapshotId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /missionRewardEvents/{rewardEventId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /itemDefinitions/{itemId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /userInventory/{inventoryItemId} {
      allow read: if isSignedIn() && resource.data.ownerUserId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /buddyCapabilities/{capabilityDocId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /nfcTags/{tagId} {
      allow read, write: if false;
    }

    match /nfcScanEvents/{scanEventId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /nfcScanClaims/{claimId} {
      allow read, write: if false;
    }

    match /capabilityUnlockEvents/{eventId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /buddyItemUseEvents/{eventId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
